# Database (Neon via Vercel Marketplace)
# A integração injeta automaticamente várias URLs. Usamos as duas que o Neon
# recomenda para Prisma serverless:
#  - POSTGRES_PRISMA_URL: pooled, já com pgbouncer=true&connect_timeout=15
#  - POSTGRES_URL_NON_POOLING: direto, usado para migrations/introspection
# Para puxar local: `vercel env pull .env`
POSTGRES_PRISMA_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require"

# Auth.js (NextAuth v5) — compartilhado por admin (Credentials)
# e customer (Google). Cookies têm nomes distintos para coexistir.
# Gerar AUTH_SECRET com: `npx auth secret` (ou openssl rand -base64 32)
AUTH_SECRET=""
# Em produção (Vercel) é detectado automaticamente; só setar localmente.
AUTH_URL="http://localhost:3000"

# Google OAuth (customer auth — /conta/login)
# Criar em: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://solarisis-app.vercel.app/api/auth/callback/google
#   (e o domínio de produção quando configurado)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Mercado Pago (Pix + cartão + boleto)
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
MP_WEBHOOK_SECRET=""

# Melhor Envio (Correios + transportadoras)
ME_TOKEN=""
ME_FROM_CEP="01310100"
ME_SANDBOX="true"

# Bling (ERP + NF-e + ponte para marketplaces)
BLING_CLIENT_ID=""
BLING_CLIENT_SECRET=""
BLING_REFRESH_TOKEN=""
BLING_NFE_SERIE="1"

# Resend (email transacional)
RESEND_API_KEY=""
EMAIL_FROM="Solarisis <pedidos@solarisis.com.br>"

# Atendimento — botão flutuante de WhatsApp na loja.
# Formato: DDI+DDD+numero, só dígitos. Vai exposto no bundle do client.
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# Sentry (opcional — monitoramento)
SENTRY_DSN=""
