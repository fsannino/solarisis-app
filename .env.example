# Database (Neon via Vercel Marketplace)
# - DATABASE_URL: pooled (PgBouncer), usado pela aplicação
# - DATABASE_URL_UNPOOLED: direto, usado pelo Prisma para migrations
# Ambas são injetadas automaticamente quando o projeto é vinculado no Vercel.
# Para puxar local: `vercel env pull .env`
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/solarisis?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.aws.neon.tech/solarisis?sslmode=require"

# Auth.js
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Mercado Pago (Pix + cartão + boleto)
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
MP_WEBHOOK_SECRET=""

# Melhor Envio (Correios + transportadoras)
ME_TOKEN=""
ME_FROM_CEP="01310100"
ME_SANDBOX="true"

# Bling (ERP + NF-e + ponte para marketplaces)
BLING_CLIENT_ID=""
BLING_CLIENT_SECRET=""
BLING_REFRESH_TOKEN=""
BLING_NFE_SERIE="1"

# Resend (email transacional)
RESEND_API_KEY=""
EMAIL_FROM="Solarisis <pedidos@solarisis.com.br>"

# Sentry (opcional — monitoramento)
SENTRY_DSN=""
