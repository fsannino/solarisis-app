// Solarisis — schema Prisma (Fase 1 + extensões para Fase 2-3)
// Referência: design_handoff_solarisis/SCHEMA.md em fsannino/solarisis

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled (PgBouncer) — usado pela aplicação em runtime.
  url       = env("DATABASE_URL")
  // Direto — usado pelo Prisma para migrations e introspection.
  // No Neon, o Vercel injeta como DATABASE_URL_UNPOOLED.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// =====================================================
// USUÁRIOS DO PAINEL ADMIN
// =====================================================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String
  image         String?
  passwordHash  String?
  role          UserRole   @default(STAFF)
  status        UserStatus @default(ACTIVE)
  permissions   String[]   // ['orders.read', 'products.write', ...]
  lastActiveAt  DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts           Account[]
  sessions           Session[]
  inventoryMovements InventoryMovement[]
  notifications      Notification[]
}

// Auth.js (NextAuth v5) — Prisma adapter standard models, ligados ao User (admin).
// Customer auth virá em PR separada com sua própria instância de Auth.js.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  OWNER
  ADMIN
  STOCK
  SUPPORT
  MARKETING
  STAFF
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

// =====================================================
// CLIENTES (LOJA)
// =====================================================

model Customer {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  phone          String?
  cpf            String?         @unique
  passwordHash   String?
  segment        CustomerSegment @default(NEW)
  totalSpent     Decimal         @default(0) @db.Decimal(10, 2)
  ordersCount    Int             @default(0)
  marketingOptIn Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lastOrderAt    DateTime?

  addresses Address[]
  orders    Order[]
  cart      Cart?
  reviews   Review[]
  returns   Return[]
}

enum CustomerSegment {
  VIP
  REGULAR
  NEW
  AT_RISK
  CHURNED
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String?  // "Casa", "Trabalho"
  recipient  String
  cep        String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String   // UF
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// =====================================================
// CATÁLOGO
// =====================================================

model Product {
  id             String          @id @default(cuid())
  sku            String          @unique
  name           String
  slug           String          @unique
  description    String          @db.Text
  category       ProductCategory
  gender         ProductGender
  type           String          // "biquíni", "camiseta", "macacão" etc
  fps            Int             @default(50)
  materials      String[]        // ["80% poliamida", "20% elastano"]
  tags           String[]
  basePrice      Decimal         @db.Decimal(10, 2)
  salePrice      Decimal?        @db.Decimal(10, 2)
  costPrice      Decimal?        @db.Decimal(10, 2)
  status         ProductStatus   @default(DRAFT)
  weight         Int?            // gramas
  dimensions     Json?           // {length, width, height} em cm
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publishedAt    DateTime?

  variants    ProductVariant[]
  images      ProductImage[]
  collections CollectionProduct[]
  listings    MarketplaceListing[]
  reviews     Review[]
}

enum ProductCategory {
  ADULTO
  INFANTIL
  ACESSORIO
}

enum ProductGender {
  FEMININO
  MASCULINO
  UNISSEX
  MENINA
  MENINO
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String   @unique
  color         String?
  size          String?
  priceOverride Decimal? @db.Decimal(10, 2)
  weight        Int?
  stock         Int      @default(0)
  createdAt     DateTime @default(now())

  orderItems     OrderItem[]
  cartItems      CartItem[]
  movements      InventoryMovement[]
  warehouseStock WarehouseStock[]

  @@unique([productId, color, size])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)
}

// =====================================================
// COLEÇÕES (curadoria visual)
// =====================================================

model Collection {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  heroImageUrl String?
  featured     Boolean  @default(false)
  status       String   @default("active")
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  products CollectionProduct[]
}

model CollectionProduct {
  collectionId String
  productId    String
  order        Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
}

// =====================================================
// CARRINHO (persistente)
// =====================================================

model Cart {
  id         String    @id @default(cuid())
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sessionId  String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items CartItem[]
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)
  addedAt   DateTime       @default(now())

  @@unique([cartId, variantId])
}

// =====================================================
// PEDIDOS
// =====================================================

model Order {
  id           String       @id @default(cuid())
  number       String       @unique // "#2026-00001"
  customerId   String
  customer     Customer     @relation(fields: [customerId], references: [id])
  status       OrderStatus  @default(PENDING)
  channel      OrderChannel @default(SITE)

  // valores
  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @default(0) @db.Decimal(10, 2)
  discount     Decimal @default(0) @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  // endereços (snapshot — não FK, para preservar histórico)
  shippingAddress Json
  billingAddress  Json

  // pagamento
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(PENDING)
  gatewayId      String?       // ID no Mercado Pago
  paymentDetails Json?         // último 4, brand, etc

  // envio
  shippingMethod String?
  trackingCode   String?
  carrier        String?

  // fiscal
  nfeNumber String?
  nfeKey    String?
  nfeUrl    String?

  // marketing
  couponCode String?
  notes      String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  canceledAt  DateTime?

  items   OrderItem[]
  events  OrderEvent[]
  returns Return[]
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELED
  RETURNED
}

enum OrderChannel {
  SITE
  ML       // Mercado Livre
  SHOPEE
  AMAZON
  MAGALU
  WHATSAPP
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
  DEBIT_CARD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
  CANCELED
}

model OrderItem {
  id           String         @id @default(cuid())
  orderId      String
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId    String
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  productName  String         // snapshot
  variantLabel String?        // snapshot ("Azul · M")
  quantity     Int
  unitPrice    Decimal        @db.Decimal(10, 2)
  totalPrice   Decimal        @db.Decimal(10, 2)
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String   // "status_changed", "payment_received", "shipped", "note"
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  createdBy String?  // userId
}

// =====================================================
// CUPONS / PROMOÇÕES
// =====================================================

model Coupon {
  id               String     @id @default(cuid())
  code             String     @unique
  type             CouponType
  value            Decimal    @db.Decimal(10, 2)
  minOrderValue    Decimal?   @db.Decimal(10, 2)
  maxUses          Int?
  usedCount        Int        @default(0)
  perCustomerLimit Int?
  appliesTo        String     @default("all") // "all" | "category:adulto" | "product:xxx"
  status           String     @default("active")
  validFrom        DateTime
  validUntil       DateTime?
  createdAt        DateTime   @default(now())
}

enum CouponType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

// =====================================================
// ESTOQUE
// =====================================================

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  cep       String
  address   String
  isPrimary Boolean  @default(false)
  status    String   @default("active")
  createdAt DateTime @default(now())

  stock     WarehouseStock[]
  movements InventoryMovement[]
}

model WarehouseStock {
  warehouseId String
  variantId   String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity    Int            @default(0)
  reserved    Int            @default(0) // reservado por pedidos pending
  updatedAt   DateTime       @updatedAt

  @@id([warehouseId, variantId])
}

model InventoryMovement {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  type        MovementType
  quantity    Int
  reason      String
  orderId     String?
  costPrice   Decimal?       @db.Decimal(10, 2)
  createdById String?
  createdBy   User?          @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
}

enum MovementType {
  IN         // entrada
  OUT        // saída
  ADJUSTMENT // ajuste manual
  TRANSFER   // transferência entre galpões
  RESERVED   // reserva
  RELEASED   // libera reserva
}

// =====================================================
// DEVOLUÇÕES
// =====================================================

model Return {
  id           String       @id @default(cuid())
  number       String       @unique // "RMA-2026-001"
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id])
  customerId   String
  customer     Customer     @relation(fields: [customerId], references: [id])
  reason       String
  reasonDetail String?      @db.Text
  status       ReturnStatus @default(REQUESTED)
  refundMethod String?
  refundAmount Decimal?     @db.Decimal(10, 2)
  items        Json         // [{orderItemId, qty, condition}]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  REFUNDED
  REJECTED
}

// =====================================================
// MARKETPLACES
// =====================================================

model MarketplaceListing {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel      OrderChannel
  externalId   String
  externalUrl  String?
  listingPrice Decimal      @db.Decimal(10, 2)
  status       String       @default("active")
  lastSyncAt   DateTime?
  errors       Json?
  createdAt    DateTime     @default(now())

  @@unique([productId, channel])
}

// =====================================================
// REVIEWS
// =====================================================

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  rating     Int      // 1-5
  title      String?
  body       String?  @db.Text
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now())
}

// =====================================================
// NOTIFICAÇÕES
// =====================================================

model Notification {
  id          String    @id @default(cuid())
  type        String    // "order_paid", "low_stock", "new_customer", ...
  title       String
  message     String    @db.Text
  audience    String    // "all" | "admin" | "customer:xxx"
  channel     String    // "email" | "push" | "sms" | "in-app"
  status      String    @default("pending")
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  metadata    Json?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

// =====================================================
// CONTEÚDO DO SITE (banners, lookbook, copy)
// =====================================================

model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique // "home_hero", "home_lookbook", "about_intro"
  type      String   // "hero", "lookbook", "richtext", "banner"
  data      Json
  status    String   @default("active")
  updatedAt DateTime @updatedAt
}

// =====================================================
// LOG DE AUDITORIA
// =====================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}
